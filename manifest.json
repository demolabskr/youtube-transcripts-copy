{
  "manifest_version": 3,
  "name": "YouTube Studio Transcript Copy",
  "version": "1.0.0",
  "description": "YouTube 스튜디오 영상 편집 페이지에 '트랜스크립트 복사' 버튼을 추가하여 영상의 전체 자막(트랜스크립트)을 클립보드로 복사합니다.",
  "permissions": ["clipboardWrite", "offscreen"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "YouTube Studio Transcript Copy",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": [
    "https://studio.youtube.com/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://studio.youtube.com/video/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page_bridge.js"],
      "matches": ["https://studio.youtube.com/*"]
    }
  ]
}
